{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "TomEE: build executable JAR",
            "type": "shell",
            "command": "mvn",
            "args": [
                "clean",
                "package",
                "-Pexecutable"
            ],
            "group": "build",
            "problemMatcher": [
                "$javac"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "TomEE: debug",
            "type": "shell",
            "command": "mvn",
            "args": [
                "clean",
                "package",
                "tomee:debug",
                "-Dtomee-plugin.debugPort=5005"
            ],
            "isBackground": true,
            "problemMatcher": {
                "owner": "java",
                "pattern": {
                    "regexp": "^(.*)$",
                    "message": 1
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Scanning for projects|tomee:.*:debug",
                    "endsPattern": "Listening for transport dt_socket at address: 5005|Server startup in"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        }
    ]
}
